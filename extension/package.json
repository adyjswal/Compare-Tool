{
  "name": "large-file-compare",
  "displayName": "Large File Compare",
  "description": "Sort and compare very large text files (200k-2M lines) such as SQL exports, CSV dumps, and structured config/property files.",
  "version": "0.1.3",
  "publisher": "AdityaKumar0406",
  "license": "MIT",
  "icon": "media/icon.png",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": ["workspace"],
  "categories": [
    "Other"
  ],
  "keywords": [
    "diff",
    "compare",
    "large files",
    "sort",
    "csv",
    "sql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adyjswal/Compare-Tool.git"
  },
  "homepage": "https://github.com/adyjswal/Compare-Tool#readme",
  "bugs": {
    "url": "https://github.com/adyjswal/Compare-Tool/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "largeFileCompare.compareFiles",
        "title": "Compare Two Files",
        "category": "Large File Compare"
      },
      {
        "command": "largeFileCompare.compareSelectedFiles",
        "title": "Diff Selected (Large File Compare)",
        "category": "Large File Compare"
      },
      {
        "command": "largeFileCompare.selectForCompare",
        "title": "Select for Diff (Large File Compare)",
        "category": "Large File Compare"
      },
      {
        "command": "largeFileCompare.compareWithSelected",
        "title": "Diff with Selected (Large File Compare)",
        "category": "Large File Compare"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "largeFileCompare.compareSelectedFiles",
          "when": "listDoubleSelection && !explorerResourceIsFolder",
          "group": "3_compare@1"
        },
        {
          "command": "largeFileCompare.selectForCompare",
          "when": "!listMultiSelection && !explorerResourceIsFolder",
          "group": "3_compare@2"
        },
        {
          "command": "largeFileCompare.compareWithSelected",
          "when": "largeFileCompare.hasSelectedForCompare && !listMultiSelection && !explorerResourceIsFolder",
          "group": "3_compare@3"
        }
      ],
      "editor/title/context": [
        {
          "command": "largeFileCompare.selectForCompare",
          "group": "3_compare@1"
        },
        {
          "command": "largeFileCompare.compareWithSelected",
          "when": "largeFileCompare.hasSelectedForCompare",
          "group": "3_compare@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "icon": "node scripts/make-icon.js",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p webview/tsconfig.json",
    "test": "vitest run",
    "vsix": "npm run package && vsce package --no-dependencies",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@large-file-compare/engine": "*",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
