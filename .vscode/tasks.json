{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "detail": "Build the engine, then bundle the extension.",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    }
  ]
}
